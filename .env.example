# ─── Piazza ───────────────────────────────────────────────
PIAZZA_EMAIL=your@email.com
PIAZZA_PASSWORD=your_password
PIAZZA_COURSE_ID=your_course_id_from_url

# ─── Groq AI (free at https://console.groq.com) ───────────
GROQ_API_KEY=your_groq_key_here

# ─── Gmail sender (use App Password, not your real password)
# Guide: https://support.google.com/accounts/answer/185833
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Report destination ────────────────────────────────────
NOTIFY_EMAIL=your@email.com

# ─── Scheduler (24h format, comma-separated) ───────────────
RUN_TIMES=09:00,17:00

# ─── Optional: path to assignment PDF for smart categorization
ASSIGNMENT_PDF_PATH=assignment.pdf
